__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

.env
.data/
.tmp_tests/
tmp/

# Agent runtime state. Keep source/configuration in the project repo, not run output.
state/*.json
state/*.jsonl
state/*.md
state/logs/
state/memories/
state/old_traces/
state/rejected_candidates/
state/skill_candidates/
state/traces/
state/verifier_reports/
state/benchmarks/

# Reusable local skills may be intentionally versioned.
!state/skills/
!state/skills/*.md

# Benchmark worker projects and generated run artifacts.
eval/workspaces/
eval/benchmarks/*/workspace/
eval/benchmarks/**/*.zip
eval/benchmarks/**/*_failed*/
eval/benchmarks/**/*_success*/
eval/benchmarks/**/*_resume_*/
eval/benchmarks/**/*_without_guard*/
eval/benchmarks/**/*_wg_failed*/

# Local diagnostics and generated outputs.
*.log
